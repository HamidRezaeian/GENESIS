{"nodes": [{"id": "docs_roadmap_graph_physics", "label": "Graph Physics Engine (genesis_engine.py / DynamicBrain, deleted)", "file_type": "concept", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Nodes predicting neighbours' states to earn energy; showed Darwinian selection, Red-Queen coevolution, catastrophe/overfitting tests and a supervised language experiment. Superseded because it was an abstract graph, not hardware, and the language result was supervised."}, {"id": "docs_roadmap_opcode_soup", "label": "1D Opcode Soup (turing_engine.py, deleted)", "file_type": "concept", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Self-replicating byte programs (OP_SPLIT, OP_ABSORB, CATALYZE...), cosmic radiation, thermodynamic zones, viscosity and a multiverse GA; produced extinction waves, junk-DNA shields, vacuum parasites. Superseded because it rewarded replication not cognition and the multiverse GA was a top-down God script (Rule 5 violation)."}, {"id": "docs_roadmap_grid_snn", "label": "2D Grid SNN Engine (deleted)", "file_type": "concept", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "64x64 toroidal world with LIF+STDP and an age-based Elite Ark. Superseded because the 2D grid was a video-game abstraction (Rule 15 violation)."}, {"id": "docs_roadmap_ram_snn_current", "label": "1D RAM Neuromorphic SNN (Current Substrate)", "file_type": "concept", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The 2D grid replaced by a literal 65536-byte RAM ring; organisms are genome-encoded sparse SNNs on a shared global heap with DNA-encoded receptor proteins, an Oracle uplink and a curriculum injector. The fourth and current of four superseded substrates."}, {"id": "docs_roadmap_tectonic_gradient", "label": "Tectonic-Gradient Principle (Rule 10)", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Forbids instantaneous, unpreventable total wipes because they prevent learning; hazards should be gradients organisms can evolve against (spatial refugia / partial die-off), not all-or-nothing extinction."}, {"id": "docs_roadmap_design_rules", "label": "GENESIS Design Rules", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The numbered operating rules governing the project (5 Intelligent Ancestor/no God script, 6 Prime Directive, 7 emergent efficiency, 9 Autotelic Imperative, 10 Tectonic-Gradient, 11/13 sparsity, 14 Elite Ark, 15 raw hardware, 16 honesty, 17 no magic constants)."}, {"id": "docs_roadmap_rule5_intelligent_ancestor", "label": "Rule 5: Intelligent Ancestor (No God Script)", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Seed a working reflex for evolution to refine rather than imposing a top-down God script; forbids wiring dashboard metrics (elite_iq) into selection."}, {"id": "docs_roadmap_rule15_raw_hardware", "label": "Rule 15: Raw Hardware Physics (No Video-Game Abstraction)", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every environmental quantity must be a raw hardware reality, not a game abstraction; one executed operation debits one honest cycle."}, {"id": "docs_roadmap_rule17_no_magic_constants", "label": "Rule 17: No Un-derived Magic Constants", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hand-tuned constants (0.1 idle discount, CYCLES_PER_EAT_GAIN, 50/50 Lamarckian blend, STDP_SCALE) must be derived from real footprint or DNA-encoded rather than arbitrary."}, {"id": "docs_roadmap_rule16_honesty", "label": "Rule 16: Honest Record-Keeping", "file_type": "rationale", "source_file": "Docs/Roadmap.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Results must describe only what the live engine measurably does; emergent cognition is a goal, not a demonstrated result. Stale claims from deleted engines are removed."}], "edges": [{"source": "docs_roadmap_ram_snn_current", "target": "docs_roadmap_graph_physics", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/Roadmap.md", "source_location": null, "weight": 1.0}, {"source": "docs_roadmap_ram_snn_current", "target": "docs_roadmap_opcode_soup", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/Roadmap.md", "source_location": null, "weight": 1.0}, {"source": "docs_roadmap_ram_snn_current", "target": "docs_roadmap_grid_snn", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/Roadmap.md", "source_location": null, "weight": 1.0}, {"source": "docs_roadmap_grid_snn", "target": "docs_roadmap_rule15_raw_hardware", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/Roadmap.md", "source_location": null, "weight": 1.0}, {"source": "docs_roadmap_opcode_soup", "target": "docs_roadmap_rule5_intelligent_ancestor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Docs/Roadmap.md", "source_location": null, "weig